# ---------------------------------------------------------------------------
# Kueue Batch Queue demo — standalone configuration. Copy to .env and edit.
#     cp .env.example .env
# Used by setup_infra.sh / deploy_app.sh / verify_setup.sh ONLY. The Hub does
# NOT read this file — it supplies its own NAMESPACE/PROJECT_NAME/REGION/
# ARTIFACT_REGISTRY_REPO and drives the feature via feature.yaml.
# ---------------------------------------------------------------------------

# Google Cloud project id. (Standalone uses PROJECT_ID; the Hub injects the
# equivalent as PROJECT_NAME — see feature.yaml template_defaults.)
PROJECT_ID=your-gcp-project-id

# GKE cluster + gateway. Use a DISTINCT cluster name so you never touch an
# existing one. GATEWAY_NAME must match metadata.name in infra/gateway.yaml.
CLUSTER_NAME=kueue-demo-cluster
GATEWAY_NAME=kueue-demo-gw

# Region / zone. REGION defaults to ZONE without its trailing -<letter>.
REGION=us-central1
ZONE=us-central1-a

# Small on-demand DEFAULT node pool. It hosts the Kueue operator and the
# controller. Admitted Job pods run on auto-provisioned Spot nodes selected by
# the kueue-demo-cpu ComputeClass (cluster/cpu-computeclass.yaml), not this pool.
MACHINE_TYPE=e2-standard-4
NUM_NODES=2

# Node Auto-Provisioning limits. NAP must be enabled so the kueue-demo-cpu
# ComputeClass can auto-create Spot node pools on demand for the Job pods.
MAX_CPU=200
MAX_MEMORY=800

# Kueue queue names. The LocalQueue is namespaced (created by deploy_app.sh); the
# ClusterQueue is cluster-scoped (created by setup_infra.sh). The controller
# submits Jobs into LOCAL_QUEUE_NAME.
LOCAL_QUEUE_NAME=kueue-demo-queue
CLUSTER_QUEUE_NAME=kueue-demo-clusterqueue

# Per-namespace deploy target. Keep "default" for standalone so ${NAMESPACE} in
# the manifests still renders; the Hub overrides this with gke-showcase-kueue.
NAMESPACE=default

# Artifact Registry repo for the image (created by deploy_app.sh if missing).
ARTIFACT_REGISTRY_REPO=kueue-demo

# Optional: image tag. Defaults to CLUSTER_NAME so multiple clusters never share
# a :latest and clobber each other's image.
# IMAGE_TAG=kueue-demo-cluster

# Controller HTTP port.
APP_PORT=8000
